// Paste this into Firebase Console → Firestore Database → Rules.
//
// IMPORTANT: This MVP version has NO AUTHENTICATION. Anyone with your
// Netlify URL can view and edit notaryJobs / apostilleRequests / notaries.
// The public /intake page is allowed to CREATE new jobs/requests only —
// but the admin dashboard (/) currently has no login gate at all.
//
// Before you put real client PII behind this, add Firebase Auth
// (email/password or Google sign-in) and tighten these rules so reads
// and updates require `request.auth != null`.

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /notaryJobs/{jobId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true; // TODO: require auth once you add login
    }

    match /apostilleRequests/{reqId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true; // TODO: require auth once you add login
    }

    match /notaries/{notaryId} {
      allow read: if true;
      allow write: if true; // TODO: require auth once you add login
    }
  }
}
